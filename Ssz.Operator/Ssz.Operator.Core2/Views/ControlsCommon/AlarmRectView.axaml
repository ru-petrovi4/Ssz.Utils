<UserControl x:Class="Ssz.Operator.Core.ControlsCommon.AlarmRectView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"             
			       xmlns:vm="using:Ssz.Operator.Core.ControlsPlay.GenericPlay"
             xmlns:conv="using:Ssz.Operator.Core.ControlsCommon"
			       x:DataType="vm:GenericDsAlarmInfoViewModel"
             mc:Ignorable="d"
             Width="14" Height="17">
  <UserControl.Resources>
    <conv:AlarmFillMultiConverter x:Key="AlarmFillMultiConverter" />
  </UserControl.Resources>
	<Rectangle Name="MainRectangle" StrokeThickness="2" Stroke="{Binding AlarmRectBrush}">
    <Rectangle.Fill>
      <MultiBinding Converter="{StaticResource AlarmFillMultiConverter}">
        <Binding Path="AlarmIsActive" />
        <Binding Path="AlarmRectBrush" />
      </MultiBinding>
    </Rectangle.Fill>
  </Rectangle>
</UserControl>