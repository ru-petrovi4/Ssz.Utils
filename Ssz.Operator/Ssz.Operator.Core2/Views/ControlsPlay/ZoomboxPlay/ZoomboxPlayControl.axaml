<controlsPlay:PlayControlBase
    xmlns:controlsPlay="clr-namespace:Ssz.Operator.Core.ControlsPlay.ZoomboxPlay"
    x:Class="Ssz.Operator.Core.ControlsPlay.ZoomboxPlay.ZoomboxPlayControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:p="clr-namespace:Ssz.Operator.Core.Properties"
    xmlns:paz="using:Avalonia.Controls.PanAndZoom">
    <Grid>
        <!--
            Аналог BusyIndicator — ActivityIndicator (или собственная реализация).
            Ниже представлен вариант с простым Grid + IsVisible для оверлея.
        -->
        <Grid x:Name="MainBusyIndicator">
            <!-- Область Pan&Zoom -->
            <paz:ZoomBorder
                x:Name="ZoomBorder"
                Stretch="None"
                ZoomSpeed="1.2"
                EnablePan="True"
                EnableZoom="True"
                ClipToBounds="True"
                Focusable="True"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent" />

            <!-- Оверлей "занято" — показывается когда IsBusy=True -->
            <Border
                x:Name="BusyOverlay"
                IsVisible="False"
                Background="#80000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
                <ProgressBar
                    IsIndeterminate="True"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="200" />
            </Border>
        </Grid>

        <!-- Панель навигации поверх ZoomBorder -->
        <StackPanel
            x:Name="NavigationPanel"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Orientation="Horizontal">
            <Button
                x:Name="Back"
                Margin="5,5,0,5"
                Width="24"
                Height="24"
                Focusable="False"
                Padding="0"
                ToolTip.Tip="{x:Static p:Resources.ZoomboxBackButtonToolTip}"
                Click="BackOnClick">
                <Image Width="18" Height="18" Stretch="Uniform"
                    Source="avares://Ssz.Operator.Core/Resources/Images/Back.png" />
            </Button>
            <Button
                x:Name="Forward"
                Margin="5,5,0,5"
                Width="24"
                Height="24"
                Focusable="False"
                Padding="0"
                ToolTip.Tip="{x:Static p:Resources.ZoomboxForwardButtonToolTip}"
                Click="ForwardOnClick">
                <Image Width="18" Height="18" Stretch="Uniform"
                    Source="avares://Ssz.Operator.Core/Resources/Images/Forward.png" />
            </Button>
            <Button
                x:Name="Home"
                Margin="5,5,0,5"
                Width="24"
                Height="24"
                Focusable="False"
                Padding="0"
                ToolTip.Tip="{x:Static p:Resources.ZoomboxHomeButtonToolTip}"
                Click="HomeOnClick">
                <Image Width="18" Height="18" Stretch="Uniform"
                    Source="avares://Ssz.Operator.Core/Resources/Images/Home.png" />
            </Button>
            <TextBlock
                x:Name="InfoTextBlock"
                Foreground="Black"
                TextAlignment="Left"
                Margin="20,0,0,0"
                IsVisible="False"
                IsHitTestVisible="False"
                Opacity="0.8"
                VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</controlsPlay:PlayControlBase>
